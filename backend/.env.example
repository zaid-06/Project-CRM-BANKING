PORT=5000
NODE_ENV=development

# Database connection (example)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=bank_finance_crm

# JWT tokens
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Enable / disable OTP for login (AUTH_USE_OTP used elsewhere in auth.controller)
AUTH_USE_OTP=true

# Use real SMS sending for phone OTP login.
# When using real SMS, you MUST also set the Twilio variables below.
# If these are missing, sending OTP will fail and API will return an error.
USE_REAL_SMS=true

# Twilio SMS configuration (required for sending OTP to mobile)
# Get these from your Twilio console.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

